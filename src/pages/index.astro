    color: var(--muted);
  }

  .terminal-body {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .trace-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  @media (min-width: 640px) {
    .trace-row {
      flex-direction: row;
      gap: 24px;
    }
  }

  .trace-row .label {
    color: #77b7ff;
    font-size: 13px;
    min-width: 90px;
  }


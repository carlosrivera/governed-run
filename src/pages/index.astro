    position: absolute;
    left: 0;
    color: var(--line-strong);
  }

  .maturity-note {
    margin: 48px 0;
  }

  .loop-step-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    margin: 40px 0;
  }

  @media (min-width: 640px) {
    .loop-step-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .loop-step {
    padding: 24px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--bg-raised);
  }

  .loop-step h4 {
    font-size: 15px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 8px;
  }

  .loop-step p {
    font-size: 14px;
    line-height: 1.5;
    margin: 0;
  }

  .comparison-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    margin: 40px 0;
  }

  @media (min-width: 640px) {
    .comparison-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .comparison-col {
    padding: 32px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--bg-raised);
  }

  .comparison-col.active {
    border-color: var(--line-strong);
    background: linear-gradient(180deg, rgba(34,34,34,0.4) 0%, rgba(17,17,17,0) 100%);
  }

  .comparison-col h3 {
    margin-bottom: 24px;
    font-size: 16px;
    color: var(--muted);
  }

  .comparison-col.active h3 {
    color: var(--text);
  }

  .clean-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .clean-list li {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--muted);
    padding-left: 16px;
    position: relative;

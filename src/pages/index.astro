  }

  .section-subhead {
    color: var(--text);
    font-size: 20px;
    margin: 8px 0 24px;
  }

  .maturity-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    margin: 0 0 48px;
  }

  @media (min-width: 640px) {
    .maturity-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }


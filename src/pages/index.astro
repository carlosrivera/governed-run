    border: 1px solid var(--line-strong);
    border-radius: 8px;
    overflow: hidden;
    margin: 24px 0 48px;
    font-family: var(--font-mono);
  }

  .terminal-header {
    background: var(--bg-raised);
    padding: 12px 16px;
    display: flex;
    align-items: center;
    gap: 8px;
    border-bottom: 1px solid var(--line);
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .dot.red { background: #ff5f56; }
  .dot.amber { background: #ffbd2e; }
  .dot.green { background: #27c93f; }


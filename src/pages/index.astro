    font-family: var(--font-mono);
    font-size: 12px;
    color: #77b7ff;
    margin-bottom: 12px;
  }

  .maturity-card h4 {
    font-size: 16px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 10px;
  }

  .maturity-card p {
    font-size: 14px;
